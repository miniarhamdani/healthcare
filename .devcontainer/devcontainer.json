{
  "name": "healthcare-complete",
  "dockerComposeFile": [
    "docker-compose.yml"
  ],
  "service": "workspace",
  "workspaceFolder": "/workspaces/healthcare-complete",
  "forwardPorts": [
    3000,
    3001
  ],
  "portsAttributes": {
    "3000": {
      "label": "Backend API",
      "onAutoForward": "notify"
    },
    "3001": {
      "label": "Frontend",
      "onAutoForward": "openBrowser"
    }
  },
  "postCreateCommand": "cd backend && npm install && cd ../frontend && npm install"
}
